# ---------------------------------------------------------------------------
# CSG Forte credentials.  NONE of these belong in the iOS app.
# Get them from: Forte dashboard -> Developer -> API Credentials
# Start with SANDBOX. Do not put production keys in source control.
# ---------------------------------------------------------------------------

# "sandbox" or "production"
FORTE_ENV=sandbox

# HTTP Basic auth pair (username:password) for the REST API.
FORTE_API_ACCESS_ID=
FORTE_API_SECURE_KEY=

# Routing. Sent as X-Forte-Auth-Organization-Id and used in the request path.
FORTE_ORGANIZATION_ID=org_000000
FORTE_LOCATION_ID=loc_000000

# ---------------------------------------------------------------------------
# Checkout page mode.
#
#   fortejs  - Card fields are Forte-controlled; the browser tokenizes directly
#              to Forte and your server only ever sees a one_time_token.
#              PCI scope: SAQ-A-EP.  THIS IS WHAT YOU SHIP.
#
#   direct   - The page posts raw PAN to this server, which calls the REST API.
#              Works immediately in sandbox with no extra setup, which makes it
#              useful for wiring things up. It puts your server in full PCI
#              scope. NEVER enable this in production.
# ---------------------------------------------------------------------------
PAYMENT_MODE=direct

# Required when PAYMENT_MODE=fortejs.
#
# NOTE: I could not verify this script URL from Forte's public documentation --
# their devdocs are a client-rendered SPA and the sample files are behind the
# support portal. Ask your Forte rep for the exact forte.js <script src> for
# each environment, or copy it out of the ForteJS integration guide at
# https://www.forte.net/devdocs/forte.js/forte.js.htm
# Guessing this value will fail silently at runtime, so it is left blank.
FORTE_JS_URL=

# The client-side API Login ID that forte.js uses to mint one-time tokens.
# Safe to expose in the page -- it can only create tokens, not move money.
FORTE_API_LOGIN_ID=

# ---------------------------------------------------------------------------
PORT=3000

# The iOS WKWebView watches for navigation to these paths to know when to
# dismiss itself. Keep in sync with ForteConfig.swift.
CHECKOUT_RETURN_SUCCESS=/checkout/complete
CHECKOUT_RETURN_CANCEL=/checkout/cancel
